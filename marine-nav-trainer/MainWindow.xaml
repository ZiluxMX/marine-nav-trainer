<Window x:Class="marine_nav_trainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:marine_nav_trainer"
        mc:Ignorable="d"
        Title="MainWindow"
        Width="1280"
        Height="720"
        SizeToContent="Manual">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1E2A38"
                Padding="10">
            
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0">

                    <TextBlock Text="PanelSterowania"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,15,0"/>

                    <Button Content="Linie pomocnicze"
                            Click="ToggleEdges_Click"
                            Padding="10,4"
                            Margin="0,0,10,0"/>

                    <Button Content="Reset Zoom"
                            Click="ResetZoom_Click"
                            Padding="10,4"/>
                    
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    
                    <TextBlock x:Name="CoordsText"
                               Foreground="White"
                               FontFamily="Consolas"
                               FontSize="14"/>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <ScrollViewer x:Name="MapScrollViewer"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="MapScrollViewer_MouseWheel_Zoom"
                      Background="#1E1E1E"
                      CanContentScroll="False">
            
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                
                <Canvas x:Name="MapCanvas"
                        MouseRightButtonDown="MapCanvas_MouseRightButtonDown"
                        MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp"
                        MouseMove="MapCanvas_MouseMove">
                    
                    <Canvas.RenderTransform>
                        <ScaleTransform x:Name="MapScale"
                                        ScaleX="1"
                                        ScaleY="1"/>
                    </Canvas.RenderTransform>

                    <Image x:Name="MapImage"
                           RenderOptions.BitmapScalingMode="LowQuality"/>

                    <Line x:Name="LeftEdge"
                          Stroke="#80FF0000"
                          StrokeThickness="2"
                          IsHitTestVisible="True"/>
                    
                    <Line x:Name="RightEdge"
                          Stroke="#80FF0000"
                          StrokeThickness="2"
                          IsHitTestVisible="True"/>
                    
                    <Line x:Name="TopEdge"
                          Stroke="#80FF0000"
                          StrokeThickness="2"
                          IsHitTestVisible="True"/>
                    
                    <Line x:Name="BottomEdge"
                          Stroke="#80FF0000"
                          StrokeThickness="2"
                          IsHitTestVisible="True"/>
                </Canvas>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>