<UserControl x:Class="marine_nav_trainer.Windows.Views.FileListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="15,10,15,10"
                BorderThickness="0,1,0,1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <ui:TextBlock Text="Lista plików" FontTypography="Subtitle" VerticalAlignment="Center"/>
                </StackPanel>
                <ui:Button x:Name="CloseButton"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Appearance="Secondary"
                           ToolTip="Zamknij"
                           Click="CloseButton_Click"
                           Padding="8">
                    <ui:SymbolIcon Symbol="Dismiss24"/>
                </ui:Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel map -->
            <ui:Card Grid.Column="0" Padding="0" VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="14,10"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Map24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ui:TextBlock Text="Mapy nawigacyjne (.pdf)" FontTypography="BodyStrong" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Wyszukiwarka map -->
                    <ui:TextBox x:Name="MapsSearchBox"
                                Grid.Row="1"
                                Margin="8,8,8,0"
                                PlaceholderText="Szukaj mapy po nazwie..."
                                ClearButtonEnabled="True"
                                TextChanged="MapsSearchBox_TextChanged">
                        <ui:TextBox.Icon>
                            <ui:SymbolIcon Symbol="Search24"/>
                        </ui:TextBox.Icon>
                    </ui:TextBox>

                    <!-- Lista map -->
                    <ListBox x:Name="MapsListBox"
                             Grid.Row="2"
                             Margin="8"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionMode="Single">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Symbol="Document24" Grid.Column="0"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SizeText}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Stopka map -->
                    <Border Grid.Row="3" Padding="10,8"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                        <Grid>
                            <TextBlock x:Name="MapsCountLabel"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       FontSize="12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:Button Margin="0,0,8,0"
                                           Appearance="Danger"
                                           ToolTip="Usuń zaznaczoną mapę"
                                           Click="DeleteMap_Click">
                                    <ui:SymbolIcon Symbol="Delete24"/>
                                </ui:Button>
                                <ui:Button Content="Eksportuj"
                                           Margin="0,0,8,0"
                                           Appearance="Secondary"
                                           Click="ExportMap_Click">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ArrowDownload24"/>
                                    </ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="Importuj mapę"
                                           Appearance="Primary"
                                           Click="ImportMap_Click">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ArrowUpload24"/>
                                    </ui:Button.Icon>
                                </ui:Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </ui:Card>

            <!-- Panel zadań JSON -->
            <ui:Card Grid.Column="2" Padding="0" VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="14,10"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DocumentText24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ui:TextBlock Text="Pliki zadań (.json)" FontTypography="BodyStrong" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Wyszukiwarka zadań -->
                    <ui:TextBox x:Name="JsonsSearchBox"
                                Grid.Row="1"
                                Margin="8,8,8,0"
                                PlaceholderText="Szukaj zadania po nazwie..."
                                ClearButtonEnabled="True"
                                TextChanged="JsonsSearchBox_TextChanged">
                        <ui:TextBox.Icon>
                            <ui:SymbolIcon Symbol="Search24"/>
                        </ui:TextBox.Icon>
                    </ui:TextBox>

                    <!-- Lista plików zadania -->
                    <ListBox x:Name="JsonsListBox"
                             Grid.Row="2"
                             Margin="8"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionMode="Single">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Symbol="DocumentBulletList24" Grid.Column="0"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SizeText}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Stopka zadań -->
                    <Border Grid.Row="3" Padding="10,8"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                        <Grid>
                            <TextBlock x:Name="JsonsCountLabel"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       FontSize="12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:Button Margin="0,0,8,0"
                                           Appearance="Danger"
                                           ToolTip="Usuń zaznaczone zadanie"
                                           Click="DeleteJson_Click">
                                    <ui:SymbolIcon Symbol="Delete24"/>
                                </ui:Button>
                                <ui:Button Content="Eksportuj"
                                           Margin="0,0,8,0"
                                           Appearance="Secondary"
                                           Click="ExportJson_Click">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ArrowDownload24"/>
                                    </ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="Importuj zadanie"
                                           Appearance="Primary"
                                           Click="ImportJson_Click">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="ArrowUpload24"/>
                                    </ui:Button.Icon>
                                </ui:Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>
