<Window x:Class="marine_nav_trainer.Windows.Views.HelpControlsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Sterowanie"
        Width="820"
        SizeToContent="Height"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="HeaderCell" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style x:Key="Cell" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="12,7"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="KeyText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DescText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="15,10"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Keyboard24" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ui:TextBlock Text="Sterowanie mapą" FontTypography="Subtitle" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
            <Border BorderThickness="1,1,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource HeaderCell}">
                        <TextBlock Text="Kombinacja" Style="{StaticResource HeaderText}"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource HeaderCell}">
                        <TextBlock Text="Działanie" Style="{StaticResource HeaderText}"/>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource KeyText}">
                            <Run Text="Ctrl + kółko myszy" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource DescText}"
                                   Text="Przybliżanie / oddalenie mapy (zoom centrowany na kursorze; ograniczony min./maks.)"/>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource KeyText}">
                            <Run Text="kółko myszy" FontWeight="SemiBold"/><Run Text=" (bez Ctrl)"/>
                        </TextBlock>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource DescText}"
                                   Text="Zwykłe przewijanie mapy w pionie"/>
                    </Border>

                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource KeyText}">
                            <Run Text="Ctrl + przeciąganie LPM" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource DescText}"
                                   Text="Przesuwanie mapy (chwyć i przeciągnij)"/>
                    </Border>

                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource KeyText}">
                            <Run Text="Alt + przeciąganie LPM" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>
                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource DescText}"
                                   Text="Przesuwanie linii kalibracyjnych („Krawędzie mapy”) – tylko gdy są widoczne"/>
                    </Border>

                    <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource KeyText}">
                            <Run Text="Prawy przycisk myszy (PPM)" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>
                    <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource DescText}"
                                   Text="Odczyt współrzędnych geograficznych φ/λ w miejscu kliknięcia (pokazywane na końcu Panelu sterowania)"/>
                    </Border>

                    <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource KeyText}">
                            <Run Text="Shift + przeciąganie LPM" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Border>
                    <Border Grid.Row="6" Grid.Column="1" Style="{StaticResource Cell}">
                        <TextBlock Style="{StaticResource DescText}"
                                   Text="Zmiana rozmiaru kroczka"/>
                    </Border>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
